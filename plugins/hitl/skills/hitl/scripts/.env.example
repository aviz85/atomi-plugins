# HITL - Human-in-the-Loop. Copy to .env and fill in.
# Shares the same Green API instance as the WhatsApp plugin.
GREEN_API_URL=https://XXXX.api.greenapi.com
GREEN_API_INSTANCE=1234567890
GREEN_API_TOKEN=your_token_here

# The owner's own WhatsApp number (approval messages are sent to self).
HITL_OWNER_PHONE=972501234567

# Optional: where the task queue lives. Default: ./hitl-queue.json in the project.
# Recommended: keep it inside your Second Brain, e.g.
# HITL_QUEUE=/Users/you/Documents/Second Brain/08-hitl/hitl-queue.json
